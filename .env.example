# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only: admin console analytics (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Server-only: password for /admin (use a long random value in production)
ADMIN_SECRET=

# Optional: admin session length in seconds (default 604800 = 7 days)
# ADMIN_SESSION_MAX_AGE_SEC=604800

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
